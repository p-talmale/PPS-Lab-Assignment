def is_prime(n):
	if n <= 1:
		return False
	if n == 2:
		return True
	if n % 2 == 0:
		return False
	for i in range(3, int(n ** 0.5) + 1, 2):
		if n % i == 0:
			return False
	return True

start = int(input())
end = int(input())

found_prime = False

for num in range(start, end + 1):
	if is_prime(num):
		print(num)
		found_prime = True

if not found_prime:
	print("No primes")
