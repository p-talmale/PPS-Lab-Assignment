n = int(input("dimension: "))

print("first matrix:")
a = []
for i in range(n):
	a.append(list(map(int, input().split())))

print("second matrix:")
b = []
for i in range(n):
	b.append(list(map(int, input().split())))

c = [[0]*n for i in range(n)]

for i in range(n):
	for j in range(n):
		for k in range(n):
			c[i][j] += a[i][k] * b[k][j]

print("Resultant Matrix:")
for i in range(n):
	for j in range(n):
		if j == n-1:
			print(c[i][j], end="")
		else:
			print(c[i][j], end=" ")
	print()
